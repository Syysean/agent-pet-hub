{
  "name": "agent-pet-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent Pet Hub - A Tauri desktop app for AI agent interaction with animated pet",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "tauri": "tauri",
    "clean": "rm -rf dist node_modules packages/protocol/node_modules"
  },
  "dependencies": {
    "@agent-pet-hub/protocol": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}

